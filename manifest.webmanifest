{
  "name": "Daily Journal",
  "short_name": "Journal",
  "description": "Personal productivity journal and chore manager",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#f6f1e8",
